# ClearScan Configuration File
# Rename this file to config.yaml and adjust settings as needed

# Database Configuration
database:
  url: "sqlite:///clearscan.db"
  pool_size: 5
  max_overflow: 10

# Security Settings
security:
  failed_login_delay: 5  # seconds
  max_failed_attempts: 5
  lockout_duration: 1800  # 30 minutes
  password_min_length: 12
  password_require_special: true
  session_timeout: 3600  # 1 hour

# Scanner Configuration
scanner:
  batch_size: 1000
  timeout: 300  # seconds
  parallel_scans: 4
  retry_attempts: 3
  retry_delay: 60  # seconds

# Notification Settings
notifications:
  telegram:
    enabled: false
    bot_token: ""
    chat_id: ""
  email:
    enabled: false
    smtp_server: ""
    smtp_port: 587
    username: ""
    password: ""
    from_address: ""
    to_addresses: []

# Logging Configuration
logging:
  level: "INFO"
  file: "clearscan.log"
  max_size: 10485760  # 10MB
  backup_count: 5
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# Web Dashboard
web:
  host: "127.0.0.1"
  port: 5000
  debug: false
  ssl:
    enabled: false
    cert_file: ""
    key_file: ""
  allowed_ips: ["127.0.0.1"] 